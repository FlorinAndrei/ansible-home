# Managed by Ansible - do not edit manually

{% for proxy in nginx_reverse_proxy_ports %}
server {
    listen {{ ansible_facts['default_ipv4']['address'] }}:{{ proxy.listen_port }};

    location / {
        proxy_pass http://127.0.0.1:{{ proxy.upstream_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

{% if nginx_reverse_proxy_tls %}
server {
    listen {{ ansible_facts['default_ipv4']['address'] }}:{{ proxy.tls_port | default(443) }} ssl;
    ssl_certificate {{ nginx_reverse_proxy_tls_cert }};
    ssl_certificate_key {{ nginx_reverse_proxy_tls_key }};

    location / {
        proxy_pass http://127.0.0.1:{{ proxy.upstream_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

{% endif %}
{% endfor %}
