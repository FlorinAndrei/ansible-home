# Managed by Ansible - do not edit manually

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen {{ ansible_facts['default_ipv4']['address'] }}:18789 ssl;
    server_name {{ inventory_hostname }} {{ inventory_hostname }}.{{ local_domain }} {{ ansible_facts['default_ipv4']['address'] }};

    ssl_certificate     /etc/nginx/certs/openclaw.crt;
    ssl_certificate_key /etc/nginx/certs/openclaw.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    location / {
        proxy_pass http://127.0.0.1:18789;
        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
        proxy_buffering off;
    }
}

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    root /var/www/html;
    index index.html index.htm index.nginx-debian.html;
    autoindex on;
    add_header Cache-Control "no-cache";

    location ~* \.md$ {
        types { }
        default_type text/plain;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
